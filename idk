<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AREEN</title>
<style>
* { box-sizing: border-box; }
html, body {
  margin: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: radial-gradient(circle at top, #10203d, #02060d 70%);
  color: #eef6ff;
  font-family: "Trebuchet MS", Arial, sans-serif;
}

#game {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.hud {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.topbar,
.leftbar,
.rightbar,
.prompt,
.toast {
  position: absolute;
  background: rgba(5, 10, 22, 0.7);
  border: 1px solid rgba(168, 216, 234, 0.25);
  backdrop-filter: blur(10px);
}

.topbar {
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  padding: 12px 18px;
  border-radius: 14px;
  text-align: center;
  min-width: 340px;
}

.title {
  font-size: 28px;
  letter-spacing: 6px;
  color: #f7d375;
}

.subtitle {
  margin-top: 6px;
  font-size: 11px;
  letter-spacing: 2px;
  color: rgba(238, 246, 255, 0.65);
  text-transform: uppercase;
}

.leftbar {
  top: 18px;
  left: 18px;
  padding: 14px 16px;
  border-radius: 14px;
  width: 240px;
}

.rightbar {
  top: 18px;
  right: 18px;
  padding: 14px 16px;
  border-radius: 14px;
  width: 240px;
}

.label {
  font-size: 11px;
  letter-spacing: 3px;
  color: rgba(168, 216, 234, 0.8);
  text-transform: uppercase;
}

.value {
  margin-top: 6px;
  font-size: 22px;
  color: #ffffff;
}

.small {
  margin-top: 10px;
  font-size: 13px;
  color: rgba(238, 246, 255, 0.7);
  line-height: 1.6;
}

.prompt {
  left: 50%;
  bottom: 28px;
  transform: translateX(-50%);
  padding: 12px 18px;
  border-radius: 999px;
  font-size: 14px;
  letter-spacing: 1px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.prompt.show {
  opacity: 1;
}

.toast {
  left: 50%;
  top: 110px;
  transform: translateX(-50%);
  padding: 10px 16px;
  border-radius: 999px;
  font-size: 13px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.toast.show {
  opacity: 1;
}

.crosshair {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20px;
  height: 20px;
  transform: translate(-50%, -50%);
}

.crosshair::before,
.crosshair::after {
  content: "";
  position: absolute;
  background: rgba(255, 255, 255, 0.45);
}

.crosshair::before {
  left: 50%;
  top: 0;
  width: 1px;
  height: 20px;
  transform: translateX(-50%);
}

.crosshair::after {
  top: 50%;
  left: 0;
  width: 20px;
  height: 1px;
  transform: translateY(-50%);
}

.battle-overlay {
  position: fixed;
  inset: 0;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(2, 6, 13, 0.82);
  z-index: 50;
}

.battle-overlay.open {
  display: flex;
}

.battle-shell {
  width: min(1120px, calc(100vw - 32px));
  height: min(760px, calc(100vh - 32px));
  border-radius: 22px;
  overflow: hidden;
  border: 1px solid rgba(247, 211, 117, 0.35);
  box-shadow: 0 20px 80px rgba(0, 0, 0, 0.45);
  background: #08111d;
  position: relative;
}

.battle-head {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: linear-gradient(180deg, rgba(5, 10, 22, 0.94), rgba(5, 10, 22, 0.4));
  pointer-events: auto;
}

.battle-title {
  font-size: 14px;
  letter-spacing: 3px;
  color: #f7d375;
  text-transform: uppercase;
}

.battle-close {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  border-radius: 999px;
  padding: 8px 12px;
  cursor: pointer;
}

#battleFrame {
  width: 100%;
  height: 100%;
  border: none;
  background: #f8f1d0;
}

@media (max-width: 780px) {
  .topbar { min-width: 0; width: calc(100vw - 24px); }
  .leftbar, .rightbar { width: 180px; }
  .value { font-size: 18px; }
}
</style>
</head>
<body>
<canvas id="game"></canvas>

<div class="hud">
  <div class="topbar">
    <div class="title">AREEN</div>
    <div class="subtitle">Skate the frozen field, challenge enemies, and trigger math duels to strike.</div>
  </div>

  <div class="leftbar">
    <div class="label">Skater</div>
    <div class="value" id="skaterName">ENZO</div>
    <div class="small" id="playerHud">HP 100 | Victories 0</div>
    <div class="small">Move with <code>WASD</code>. Press <code>F</code> near an enemy to attack.</div>
  </div>

  <div class="rightbar">
    <div class="label">Frozen Wilds</div>
    <div class="value" id="enemyCount">3 Enemies</div>
    <div class="small" id="worldHud">Find a foe and enter spell combat.</div>
  </div>

  <div class="toast" id="toast">Enemy defeated.</div>
  <div class="prompt" id="prompt">Press F to challenge this enemy.</div>
  <div class="crosshair"></div>
</div>

<div class="battle-overlay" id="battleOverlay">
  <div class="battle-shell">
    <div class="battle-head">
      <div class="battle-title" id="battleTitle">Spell Duel</div>
      <button class="battle-close" id="battleClose" type="button">Close</button>
    </div>
    <iframe id="battleFrame" title="Math Battle"></iframe>
  </div>
</div>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

const player = { x: 0, y: 0, r: 16, speed: 3.1, hp: 100, victories: 0 };
const worldRadius = 620;
const keys = {};
let activeEnemy = null;
let battleOpen = false;
let toastTimer = null;

const enemies = [
  { id: "ice-wisp", name: "Ice Wisp", x: 180, y: -120, r: 20, hp: 120, attack: 10, armor: 1, thorns: 0, fury: 1, alive: true, color: "#8bd3ff" },
  { id: "ember-wolf", name: "Ember Wolf", x: -220, y: 80, r: 24, hp: 155, attack: 12, armor: 2, thorns: 1, fury: 1, alive: true, color: "#ff8d57" },
  { id: "void-stag", name: "Void Stag", x: 70, y: 240, r: 28, hp: 190, attack: 14, armor: 3, thorns: 1, fury: 2, alive: true, color: "#d9b8ff" }
];

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}

function clampPlayer() {
  const dist = Math.hypot(player.x, player.y);
  if (dist > worldRadius) {
    player.x = (player.x / dist) * worldRadius;
    player.y = (player.y / dist) * worldRadius;
  }
}

function nearestEnemy() {
  let best = null;
  let bestDist = Infinity;
  enemies.forEach((enemy) => {
    if (!enemy.alive) return;
    const dist = Math.hypot(player.x - enemy.x, player.y - enemy.y);
    if (dist < bestDist) {
      bestDist = dist;
      best = { enemy, dist };
    }
  });
  return best;
}

function showToast(message) {
  const toast = document.getElementById("toast");
  toast.textContent = message;
  toast.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove("show"), 2200);
}

function updateHud() {
  const alive = enemies.filter((enemy) => enemy.alive).length;
  document.getElementById("enemyCount").textContent = `${alive} ${alive === 1 ? "Enemy" : "Enemies"}`;
  document.getElementById("playerHud").textContent = `HP ${player.hp} | Victories ${player.victories}`;

  const nearest = nearestEnemy();
  const prompt = document.getElementById("prompt");
  const worldHud = document.getElementById("worldHud");

  if (nearest && nearest.dist < 90 && !battleOpen) {
    prompt.classList.add("show");
    prompt.textContent = `Press F to challenge ${nearest.enemy.name}.`;
    worldHud.textContent = `${nearest.enemy.name} is ${Math.round(nearest.dist)}m away.`;
  } else {
    prompt.classList.remove("show");
    worldHud.textContent = alive ? "Find a foe and enter spell combat." : "The frozen field is quiet. You won the hunt.";
  }
}

function drawWorld() {
  const w = canvas.width;
  const h = canvas.height;
  ctx.clearRect(0, 0, w, h);

  const cx = w / 2;
  const cy = h / 2;
  ctx.fillStyle = "#08111d";
  ctx.fillRect(0, 0, w, h);

  const ice = ctx.createRadialGradient(cx, cy, 80, cx, cy, Math.max(w, h));
  ice.addColorStop(0, "#1a3357");
  ice.addColorStop(0.55, "#0b1830");
  ice.addColorStop(1, "#02060d");
  ctx.fillStyle = ice;
  ctx.fillRect(0, 0, w, h);

  ctx.save();
  ctx.translate(cx - player.x, cy - player.y);

  ctx.strokeStyle = "rgba(168,216,234,0.15)";
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.arc(0, 0, worldRadius, 0, Math.PI * 2);
  ctx.stroke();

  for (let ring = 160; ring < worldRadius; ring += 150) {
    ctx.strokeStyle = "rgba(168,216,234,0.08)";
    ctx.beginPath();
    ctx.arc(0, 0, ring, 0, Math.PI * 2);
    ctx.stroke();
  }

  enemies.forEach((enemy) => {
    if (!enemy.alive) return;
    ctx.fillStyle = enemy.color;
    ctx.shadowColor = enemy.color;
    ctx.shadowBlur = 18;
    ctx.beginPath();
    ctx.arc(enemy.x, enemy.y, enemy.r, 0, Math.PI * 2);
    ctx.fill();
    ctx.shadowBlur = 0;

    ctx.fillStyle = "#ffffff";
    ctx.font = "12px Trebuchet MS";
    ctx.textAlign = "center";
    ctx.fillText(enemy.name, enemy.x, enemy.y - enemy.r - 10);
  });

  ctx.fillStyle = "#f7d375";
  ctx.beginPath();
  ctx.moveTo(player.x, player.y - player.r);
  ctx.lineTo(player.x + player.r * 0.8, player.y + player.r);
  ctx.lineTo(player.x - player.r * 0.8, player.y + player.r);
  ctx.closePath();
  ctx.fill();

  ctx.restore();
}

function tick() {
  if (!battleOpen) {
    let dx = 0;
    let dy = 0;
    if (keys["KeyW"]) dy -= 1;
    if (keys["KeyS"]) dy += 1;
    if (keys["KeyA"]) dx -= 1;
    if (keys["KeyD"]) dx += 1;
    const mag = Math.hypot(dx, dy) || 1;
    player.x += (dx / mag) * player.speed;
    player.y += (dy / mag) * player.speed;
    clampPlayer();
  }

  drawWorld();
  updateHud();
  requestAnimationFrame(tick);
}

function openBattle(enemy) {
  activeEnemy = enemy;
  battleOpen = true;
  document.getElementById("battleTitle").textContent = `Spell Duel: ${enemy.name}`;
  const frame = document.getElementById("battleFrame");
  const params = new URLSearchParams({
    embed: "1",
    enemyName: enemy.name,
    enemyFlavor: "A frozen foe lunges from the AREEN field.",
    enemyHP: String(enemy.hp),
    enemyAttack: String(enemy.attack),
    enemyArmor: String(enemy.armor),
    enemyThorns: String(enemy.thorns),
    enemyFury: String(enemy.fury),
    enemyBonus: "This enemy was pulled from the frozen field into a spell duel."
  });
  frame.src = `./enzo4.html?${params.toString()}`;
  document.getElementById("battleOverlay").classList.add("open");
}

function closeBattle() {
  battleOpen = false;
  activeEnemy = null;
  document.getElementById("battleOverlay").classList.remove("open");
  document.getElementById("battleFrame").src = "about:blank";
}

function handleBattleResult(data) {
  if (!activeEnemy) return;

  if (data.result === "win") {
    activeEnemy.alive = false;
    player.victories += 1;
    showToast(`${activeEnemy.name} defeated.`);
  } else {
    player.hp = Math.max(0, player.hp - 12);
    showToast(`${activeEnemy.name} drove you back.`);
  }

  closeBattle();
}

window.addEventListener("message", (event) => {
  if (!event.data || event.data.type !== "enzo4-battle-result") return;
  handleBattleResult(event.data);
});

window.addEventListener("keydown", (event) => {
  keys[event.code] = true;
  if (event.code === "KeyF" && !battleOpen) {
    const nearest = nearestEnemy();
    if (nearest && nearest.dist < 90) {
      openBattle(nearest.enemy);
    } else {
      showToast("No enemy close enough to challenge.");
    }
  }
  if (event.code === "Escape" && battleOpen) {
    closeBattle();
  }
});

window.addEventListener("keyup", (event) => {
  keys[event.code] = false;
});

document.getElementById("battleClose").addEventListener("click", closeBattle);
window.addEventListener("resize", resize);

resize();
tick();
</script>
</body>
</html>
